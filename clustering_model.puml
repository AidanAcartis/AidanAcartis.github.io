@startuml clustering_model

skinparam defaultFontName Arial
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam ArrowColor #555555
skinparam ArrowThickness 1.5

skinparam rectangle {
  BorderColor #888888
  BorderThickness 1
  FontSize 13
}

title Clustering Model Architecture & Inference Pipeline

' ─────────────────────────────────────────────
' SECTION 1: BACKBONE MODEL
' ─────────────────────────────────────────────

package "Backbone: SentenceTransformer (fine-tuned MiniLM-L6-v2)" #EEF0FF {

  rectangle "Raw Text Input" as INPUT #DDDDDD
  rectangle "WordPiece Tokenizer\nmax_seq_length=256 · vocab=30k" as TOKENIZER #DDDDDD
  rectangle "Token Embeddings\nToken + Position + Segment → 384-d" as EMBED #C8C4F0

  package "BERT Encoder (6 Transformer Layers)" #D8D4F8 {
    rectangle "Transformer Block 1" as B1 #C8C4F0
    rectangle "Transformer Block 2" as B2 #C8C4F0
    rectangle "Transformer Blocks 3–5" as B35 #C8C4F0
    rectangle "Transformer Block 6" as B6 #C8C4F0
  }

  rectangle "Mean Pooling\nAggregate token embeddings" as POOL #A8DCC8
  rectangle "L2 Normalization\nUnit vector (cosine similarity space)" as NORM #A8DCC8
  rectangle "Final Embedding (384-d vector)" as OUT #F5C870

  INPUT --> TOKENIZER
  TOKENIZER --> EMBED
  EMBED --> B1
  B1 --> B2
  B2 --> B35
  B35 --> B6
  B6 --> POOL
  POOL --> NORM
  NORM --> OUT
}

' ─────────────────────────────────────────────
' SECTION 2: INFERENCE PIPELINE
' ─────────────────────────────────────────────

package "Inference Pipeline: Clusterer.cluster()" #F0F8F0 {

  rectangle "Step 1: Load Dataset (CSV)" as S1 #DDDDDD
  rectangle "Step 2: Text Normalization\n(lowercase, strip, deduplicate)" as S2 #DDDDDD
  rectangle "Step 3: Shuffle (fixed seed)" as S3 #DDDDDD
  rectangle "Step 4: Encode with SBERT\n(batch embeddings 384-d)" as S4 #C8C4F0
  rectangle "Step 5: Distance Matrix\n1 - cosine similarity" as S5 #C8C4F0

  rectangle "Step 6: Initial Hierarchical Clustering\nSilhouette score optimization" as S6 #A8DCC8

  package "Iterative Reclustering Module" #D8F0E4 {

    rectangle "Step 7: Cluster Queue Processing" as S7 #A8DCC8
    rectangle "Step 8: Cohesion Computation\n(mean intra-cluster distance)" as S8 #A8DCC8

    rectangle "Decision: Cohesion > threshold\nOR cluster size > limit ?" as D1 #FFFFFF

    rectangle "Step 9: Split Clusters (Agglomerative k=2..n)" as S9 #A8DCC8
    rectangle "Stable Cluster Output" as SF #DDDDDD
  }

  rectangle "Step 10: Post-processing\n(singletons, reassignment, merge)" as S10 #F5B8A0
  rectangle "Step 11: Final Clusters Dictionary" as S11 #A8DCC8
  rectangle "Step 12: Report Generation\n(silhouette + cohesion)" as S12 #DDDDDD
  rectangle "Final Output" as RET #F5C870

  S1 --> S2
  S2 --> S3
  S3 --> S4
  S4 --> S5
  S5 --> S6
  S6 --> S7
  S7 --> S8
  S8 --> D1

  D1 --> S9 : YES
  D1 --> SF : NO

  S9 --> S7 : iterate
  SF --> S10
  S9 --> S10

  S10 --> S11
  S11 --> S12
  S12 --> RET
}

' ─────────────────────────────────────────────
' GLOBAL CONNECTION (SAFE VERSION)
' ─────────────────────────────────────────────

OUT --> S4 : embeddings (384-d vectors)

@enduml
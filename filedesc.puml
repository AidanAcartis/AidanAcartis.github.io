@startuml filedescgen_architecture

skinparam defaultFontName Arial
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam ArrowColor #555555
skinparam ArrowThickness 1.5

skinparam rectangle {
  BorderColor #888888
  BorderThickness 1
  FontSize 13
}

title FileDescGen Backbone Architecture: Multi-Modal Semantic Fusion

' ─────────────────────────────────────────────
' SECTION 1: SEMANTIC BRANCH
' ─────────────────────────────────────────────

package "Semantic Feature Extraction (Frozen)" #EEF0FF {
  rectangle "Raw Filename\n(String Input)" as RF #DDDDDD
  rectangle "Sentence-Transformer\n(all-MiniLM-L6-v2)" as ST #C8C4F0
  rectangle "Lexical Vector\n(384-d embedding)" as LV #C8C4F0
  rectangle "Linear Projector\n(nn.Linear 384 → 512)" as LP #F3E5F5
  
  RF --> ST
  ST --> LV
  LV --> LP
}

' ─────────────────────────────────────────────
' SECTION 2: TEXTUAL BRANCH
' ─────────────────────────────────────────────

package "Textual Embedding (Input)" #F0F8F0 {
  rectangle "Instruction Prompt\n(Token IDs)" as TP #DDDDDD
  rectangle "T5 Token Embedder\n(Frozen Weight)" as TTE #A8DCC8
  rectangle "Prompt Matrix\n(L x 512-d)" as PM #A8DCC8
  
  TP --> TTE
  TTE --> PM
}

' ─────────────────────────────────────────────
' SECTION 3: FUSION & BACKBONE
' ─────────────────────────────────────────────

package "Fusion Engine & T5 Backbone" #FFF8EE {
  
  rectangle "Element-wise Summation\n(Broadcasting on Length L)" as EWS #F5C870
  
  package "Sequence-to-Sequence Generation (Flan-T5)" #F5F5F5 {
    rectangle "T5 Encoder\n(8 Layers / 6 Heads)" as T5E #D8D4F8
    rectangle "Cross-Attention\nMechanism" as CAM #C8C4F0
    rectangle "T5 Decoder\n(Autoregressive)" as T5D #D8D4F8
  }

  rectangle "Generated Natural Language\nDescription" as RESULT #F5B8A0

  PM --> EWS
  LP --> EWS : "Projected Context\n(1 x 512-d)"
  
  EWS --> T5E
  T5E --> CAM
  CAM --> T5D
  T5D --> RESULT
}

note bottom of EWS
  **Technical Logic:**
  T_fused = T_text + proj(V_lexical)
  Enriches each prompt token with
  global semantic file context.
end note

@enduml
@startuml newsgroups_pipeline_architecture

skinparam defaultFontName Arial
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam ArrowColor #555555
skinparam ArrowThickness 1.5

skinparam rectangle {
  BorderColor #888888
  BorderThickness 1
  FontSize 13
}

title 20 Newsgroups Classification: Noise Removal & Multi-Model Benchmarking

' ─────────────────────────────────────────────
' SECTION 1: DATA LOADING & EDA
' ─────────────────────────────────────────────

package "Step 1: Data Ingestion & EDA" #F0F8F0 {
  rectangle "Raw Scikit-Learn\n20Newsgroups" as RAW #DDDDDD
  rectangle "Exploratory Data Analysis\n(Imbalance, Outliers, t-SNE)" as EDA #A8DCC8
  
  RAW --> EDA
}

' ─────────────────────────────────────────────
' SECTION 2: CUSTOM PREPROCESSING (THE BACKBONE)
' ─────────────────────────────────────────────

package "Step 2: Noise Removal Backbone" #EEF0FF {
  
  rectangle "Input Text" as TEXT #DDDDDD
  
  package "extract_subject_text()" #D8D4F8 {
    rectangle "Regex Header Parser\n(Subject vs Body)" as PARSER #C8C4F0
  }
  
  package "clean_footer()" #D8D4F8 {
    rectangle "Separator Detection\n(---, ===, #)" as SEP #C8C4F0
    rectangle "Signature Pattern Matcher\n(Email, Uni, Phone)" as SIG #C8C4F0
    rectangle "Skip Logic\n(all / until_empty)" as SKIP #C8C4F0
  }

  rectangle "Final Cleaned Text\n(Noise-free Body)" as CLEANED #F5C870

  EDA --> TEXT
  TEXT --> PARSER
  PARSER --> SEP
  SEP --> SIG
  SIG --> SKIP
  SKIP --> CLEANED
}

' ─────────────────────────────────────────────
' SECTION 3: FEATURE EXTRACTION & TRAINING
' ─────────────────────────────────────────────

package "Step 3: Training & Benchmarking" #FFF8EE {
  
  rectangle "Train / Val / Test Split\n(0.8 / 0.1 / 0.1)" as SPLIT #DDDDDD

  package "Vectorization Strategies" #F5F5F5 {
    rectangle "Bag-of-Words\n(CountVectorizer)" as BOW #F5C870
    rectangle "TF-IDF\n(Term Frequency)" as TFIDF #F5C870
    rectangle "N-Grams\n(Unigrams + Bigrams)" as NGRAM #F5C870
  }

  package "Classification Algorithms" #D8F0E4 {
    rectangle "Softmax / Logistic" as SM #A8DCC8
    rectangle "SVM (Linear Kernel)" as SVM #A8DCC8
    rectangle "Random Forest" as RF #A8DCC8
    rectangle "Gradient Boosting" as GB #A8DCC8
  }

  CLEANED --> SPLIT
  SPLIT --> BOW
  SPLIT --> TFIDF
  SPLIT --> NGRAM

  BOW --> SM
  TFIDF --> SVM
  NGRAM --> RF
  TFIDF --> GB
}

' ─────────────────────────────────────────────
' SECTION 4: OUTPUT
' ─────────────────────────────────────────────

rectangle "Performance Metrics\n(Accuracy & ROUGE)" as OUT #F5B8A0

SM --> OUT
SVM --> OUT
RF --> OUT
GB --> OUT

note right of OUT
  **Best Performer:**
  TF-IDF + Linear SVM
  Test Score: 0.741
end note

@enduml